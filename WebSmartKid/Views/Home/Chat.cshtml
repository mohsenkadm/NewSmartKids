<section class="session_chat">
    <div class="chatwidth" style="">
        <div class="text-center price-title wow fadeInDown">
            <div class="row">
                <div class="col-lg-1 col-md-1 col-sm-1 col-xs-1">
                    <a class="" onclick="call_Action('Home/Index')"><i class='icon tf-ion-arrow-left-c' style="font-size:175%;"></i></a>
                </div>
                <div class="col-lg-1 col-md-1 col-sm-1 col-xs-1">
                    <a class="" onclick="call_Action(GetMessageList())" data-toggle='modal' data-target='#messagemodel'><i class='icon tf-ion-chatboxes' style="font-size:175%;"></i></a>
                </div>
                <div id="userchatinfoid" class="col-lg-9 col-md-9 col-sm-9 col-xs-9 " style="margin-left:30%">
                </div>
            </div>
        </div>
    </div>
    <div id="messges" class="chatmassagewidth container text-center" style=" height: 90%;   overflow: visible; background-color: transparent;">
    </div>
</section>
<section style="position:fixed; top:88%; left:0px; width:100%;">
    <div class="chatwidth" style="">
        <div class="text-center price-title ">
            <div class="row">
                <div class="col-lg-9 col-md-9 col-sm-9 col-xs-9">
                    <input type="text" style="margin-left:10%;  " class="bo form-control alignright" autocomplete="off" name="messagetext" id="messagetext" placeholder="اكتب رقم المستخدم"> 
                </div>
                <div class="col-lg-1 col-md-1 col-sm-1 col-xs-1" style="margin-left:6%">
                    <button id="sendmessage" type='button' class='btn btn-success btnwidth' > <i class='material-icons'>send</i></button>
                </div>
            </div>
        </div>
    </div>
</section>
<div id="mydiv">
    <script>

        $(document).ready(function () {
            call_ajax("GET", "Chat/GetMessageChatForWeb", null, GetMessagechat);
        });
        var input = document.getElementById("messagetext");

        input.addEventListener("keyup", function (event) {
            if (event.keyCode === 13) {
                event.preventDefault();
                $("#sendmessage").click();
            }
        });

        $("#sendmessage").on("click", (e) => {
            e.preventDefault();
            var object = {
                message: $("#messagetext").val(),
            };
            if (object.message === "" || object.message.trim() === "") {
                return;
            }
            call_ajax("POST", "Chat/SendMessage", object, RefreshChat);
            $("#messagetext").val("");
        });

    </script>
</div>