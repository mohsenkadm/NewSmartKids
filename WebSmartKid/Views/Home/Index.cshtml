@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
                <div class="card card-stats">
                    <div class="card-header card-header-warning card-header-icon">
                        <div class="card-icon">
                            <i class="material-icons">person</i>
                        </div>
                        <p class="card-category">عدد الزبائن</p>
                        <h3 class="card-title" id="CountUser">
                        </h3>
                    </div>
                    <div class="card-footer">
                        <div class="stats">
                            <i class="material-icons text-warning">person</i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
                <div class="card card-stats">
                    <div class="card-header card-header-success card-header-icon">
                        <div class="card-icon">
                            <i class="material-icons">person</i>
                        </div>
                        <p class="card-category">عدد القوائم</p>
                        <h3 class="card-title" id="CountOrder"></h3>
                    </div>

                    <div class="card-footer">
                        <div class="stats">
                            <i class="material-icons text-success">person</i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
                <div class="card card-stats">
                    <div class="card-header card-header-danger card-header-icon">
                        <div class="card-icon">
                            <i class="material-icons">attach_money</i>
                        </div>
                        <p class="card-category">اجمالي المبيعات</p>
                        <h3 class="card-title" id="PriceSale">90</h3>
                    </div>
                    <div class="card-footer">
                        <div class="stats">
                            <i class="material-icons text-danger">attach_money</i>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-lg-6 col-md-6 col-sm-6">
                <div class="card card-stats">
                    <div class="card-header card-header-info card-header-icon">
                        <div class="card-icon">
                            <i class="material-icons">attach_money</i>
                        </div>
                        <p class="card-category">عدد المواد</p>
                        <h3 class="card-title" id="CountItem">90</h3>
                    </div>

                    <div class="card-footer">
                        <div class="stats">
                            <i class="material-icons text-info">attach_money</i>
                        </div>
                    </div>
                </div>
            </div>
        </div> 
    </div>
</div>
<div class="container-fluid">
    <div class="copyright float-right" id="date">
        © 2022
        , made with <i class="material-icons">favorite</i> by
        <a href="#">Developer mohsen</a> for a better web.
    </div>
</div>


<div id="mydiv">
    <script>
        $(document).ready(function () {
            call_ajax("GET", "Home/GetCountForMain", null, filldatacount);
        });
        function filldatacount(data) { 
            $("#CountUser").html(data.countUser);
            $("#CountOrder").html(data.countOrder);
            $("#PriceSale").html(data.priceSale);
            $("#CountItem").html(data.countItem);
        }
    </script>
</div>

