
@{
    ViewData["Title"] = "كشف كميات المنتجات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid">
            <div class="container alignright" style="margin:2% 0;">
                <div class="row">
                    <div class="col-lg-4 col-md-4 col-sm-12 ">
                        <label class="mb-2">بحث عن الاسم</label>
                        <input type="text" class="form-control alignright" placeholder="اكتب الاسم" name="namese" id="namese">
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12 ">
                        <label class="mb-2">الصنف</label>
                        <select class="form-control alignright" style="background-color: #1a2035;" name="CategoriesIdse" id="CategoriesIdse">
                        </select>
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-2 col-xs-2">
                        <div class="text-center wow fadeInDown" style="text-align:left;">
                            <label class="mb-2"> </label>
                            <button type="button" id="search-btn" class="btn btn-info btnwidth" style="text-align:center; width:100%;">بحث <i class='material-icons'>search</i>  </button>
                        </div>
                    </div> 
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header card-header-primary" style="text-align:right">
                            <h4 class="card-title ">المنتجات</h4>
                            <p class="card-category">جدول لعرض المنتجات داخل التطبيق</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="text-align: right;">
                                <table class="table table-hover">
                                    <thead class=" ">
                                        <tr> 
                                            <th scope="col">مبلغ الكمية المباعة</th>
                                            <th scope="col">كمية المباعة</th>
                                            <th scope="col">مبلغ كمية الحالية</th>
                                            <th scope="col">كمية الحالية</th>
                                            <th scope="col">السعر</th> 
                                            <th scope="col">الاسم</th>
                                            <th scope="col">الصنف</th> 
                                        </tr>
                                    </thead>
                                    <tbody id="tableProducts">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<nav aria-label="Page navigation example" style="margin:auto 50%;">
    <ul class="pagination">
        <li class="page-item">
            <a class="page-link" href="#" id="prev" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
                <span class="sr-only">Previous</span>
            </a>
        </li>
        <li class="page-item"><a class="page-link" href="#" id="indexid">1</a></li>
        <li class="page-item">
            <a class="page-link" href="#" id="next" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
                <span class="sr-only">Next</span>
            </a>
        </li>
    </ul>
</nav>

<div id="mydiv">
    <script>

        function filltableReportQty(data) {
            $('#tableProducts').empty();
            $.each(data, function (i, item) {
                var rows = "<tr>" +  
                    "<td>" + item.sumPriceQtySales + "</td>" +
                    "<td>" + item.qtySales + "</td>" +
                    "<td>" + item.sumPriceQtyCurrent + "</td>" +
                    "<td>" + item.qtyCurrent + "</td>" +
                    "<td>" + item.price + "</td>" + 
                    "<td>" + item.name + "</td>" +
                    "<td>" + item.categoriesName + "</td></tr>";
                $('#tableProducts').append(rows);
                $('#IsDiscount' + item.productsId).attr('checked', item.isDiscount);
            });
        }

        function selectCategoriesId(data) {
            var s = '<option value="0">اختيار الصنف</option>';
            $('#CategoriesIdse').append(s);
            $('#CategoriesId').append(s);
            $.each(data, function (i, item) {
                var ss = '<option value="' + item.categoriesId + '">' + item.categoriesName + '</option>';
                $('#CategoriesIdse').append(ss);
                $('#CategoriesId').append(ss);
            });
        };
        $(document).ready(function () {
            call_ajax("GET", "Categories/GetAll", null, selectCategoriesId);

            var obj = { Name: '', CategoriesId: 0, index: 1 }
            call_ajax("GET", "Products/ReportQtyGetAll", obj, filltableReportQty);
            $("#indexid").text(1);
        });
         
        $("#search-btn").on("click", (e) => {
            e.preventDefault();
            var obj = { Name: $("#namese").val(), CategoriesId: $("#CategoriesIdse").val(), index: 1 }
            call_ajax("GET", "Products/ReportQtyGetAll", obj, filltableReportQty);
            $("#indexid").text(1);
        });

        $("#next").on("click", (e) => {
            e.preventDefault();
            var count = $("#indexid").text();
            count++;
            var obj = { Name: $("#namese").val(), CategoriesId: $("#CategoriesIdse").val(), index: count }
            call_ajax("GET", "Products/ReportQtyGetAll", obj, filltableReportQty);
            $("#indexid").text(count);
        });
        $("#prev").on("click", (e) => {
            e.preventDefault();
            var count = $("#indexid").text();
            if (count > 1) {
                count--;
                var obj = { Name: $("#namese").val(), CategoriesId: $("#CategoriesIdse").val(), index: count }
                call_ajax("GET", "Products/ReportQtyGetAll", obj, filltableReportQty);
                $("#indexid").text(count);
            }
        });
    </script>
</div>

