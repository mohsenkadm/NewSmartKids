
@{
    ViewData["Title"] = "نوع الخصم";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid"> 
            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header card-header-primary" style="text-align:right">
                            <h4 class="card-title ">نوع الخصم</h4>
                            <p class="card-category">جدول لعرض انواع الخصم داخل التطبيق</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="text-align: right;">
                                <table class="table table-hover">
                                    <thead class=" ">
                                        <tr>
                                            <th scope="col">النسبة او المبلغ</th>
                                            <th scope="col">نوع الخصم</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tableTypeDiscount">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="TypeDiscountModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dark-edition">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">اضافة جديد</h5>
                <button type="button" style="margin-left:10%;" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" style="font-size:155%">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="row">
                        <div class="form-group col-md-12  alignright">
                            <label class="text-primary">نسبة او المبلغ</label>
                            <input type="text" id="Price" autocomplete="off" name="Price" class="form-control alignright" placeholder="اكتب نسبة او المبلغ" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">اغلاق</button>
                <button type="button" class="btn btn-success" id="save">حفظ</button>
            </div>
        </div>
    </div>
</div>
<div id="mydiv">
    <script>

        $(document).ready(function () {
            call_ajax("GET", "TypeDiscount/GetAll", null, filltableTypeDiscount);
        });
        $("#save").on("click", (e) => {
            e.preventDefault();

            var object = {
                Id: _Id, 
                Price: $("#Price").val(),
            };

            if (object.Price === "" || object.Price.trim() === "") {
                md.showNotification("رجاءا ادخل السعر ");
                return;
            }

            call_ajax("POST", "TypeDiscount/Post", object, aftersaveTypeDiscount);
        });

    </script>
</div>

