@{
    ViewData["Title"] = "البرومو كود";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="content dark-edition">
        <div class="container-fluid">
            <div class="container alignright" style="margin:2% 0;">
                <div class="row">
                    <div class="col-lg-6 col-md-6 col-sm-12">
                        <label class="mb-2">بحث عن الاسم</label>
                        <input type="text" class="form-control alignright" placeholder="اكتب الاسم" name="namese" id="namese">
                    </div>
                    <div class="col-lg-4 col-md-4 col-sm-12">
                        <label class="mb-2">الحالة</label>
                        <select class="form-control alignright" style="background-color: #1a2035;" name="IsActivese" id="IsActivese">
                            <option value="">الكل</option>
                            <option value="true">نشط</option>
                            <option value="false">غير نشط</option>
                        </select>
                    </div>
                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2">
                        <div class="text-center wow fadeInDown" style="text-align:left;">
                            <label class="mb-2"> </label>
                            <button type="button" id="search-btn" class="btn btn-info btnwidth" style="text-align:center; width:100%;">بحث <i class='material-icons'>search</i></button>
                        </div>
                    </div>
                    <div class="col-lg-1 col-md-1 col-sm-2 col-xs-2">
                        <div class="text-center wow fadeInDown">
                            <label class="mb-2"> </label>
                            <button type="button" class="btn btn-success btnwidth" style="text-align:center; width:100%;" data-toggle="modal" data-target="#PromoCodeModal">اضافة جديد <i class='material-icons'>add</i></button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <div class="card">
                        <div class="card-header card-header-primary" style="text-align:right">
                            <h4 class="card-title">البرومو كود</h4>
                            <p class="card-category">جدول لعرض أكواد الخصم</p>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" style="text-align: right;">
                                <table class="table table-hover">
                                    <thead class="">
                                        <tr>
                                            <th scope="col">تاريخ الإنشاء</th>
                                            <th scope="col">الحالة</th>
                                            <th scope="col">المبلغ</th>
                                            <th scope="col">الاسم</th>
                                            <th scope="col">عدد الاستخدامات</th>
                                            <th scope="col"></th>
                                        </tr>
                                    </thead>
                                    <tbody id="tablePromoCode">
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Pagination -->
<nav aria-label="Page navigation example" style="margin:auto 50%;">
    <ul class="pagination">
        <li class="page-item">
            <a class="page-link" href="#" id="prev" aria-label="Previous">
                <span aria-hidden="true">&laquo;</span>
                <span class="sr-only">Previous</span>
            </a>
        </li>
        <li class="page-item"><a class="page-link" href="#" id="indexid">1</a></li>
        <li class="page-item">
            <a class="page-link" href="#" id="next" aria-label="Next">
                <span aria-hidden="true">&raquo;</span>
                <span class="sr-only">Next</span>
            </a>
        </li>
    </ul>
</nav>

<!-- Modal Add/Edit PromoCode -->
<div class="modal fade" id="PromoCodeModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content dark-edition">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">إضافة/تعديل برومو كود</h5>
                <button type="button" style="margin-left:10%;" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" style="font-size:155%">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="form-group col-md-12 alignright">
                        <label class="text-primary">اسم البرومو كود</label>
                        <input type="text" id="Name" autocomplete="off" name="Name" class="form-control alignright" placeholder="مثال: WELCOME50" />
                    </div>
                </div>
                <div class="row">
                    <div class="form-group col-md-6 alignright">
                        <label class="text-primary">المبلغ</label>
                        <input type="number" step="0.01" id="Amount" autocomplete="off" name="Amount" class="form-control alignright" placeholder="اكتب المبلغ" />
                    </div>
                    <div class="form-group col-md-6 alignright">
                        <label class="text-primary">نشط</label>
                        <div class='form-check col-md-6 alignright'>
                            <label class='form-check-label'>
                                <input class='form-check-input' type='checkbox' id='IsActiveca' checked>
                                <span class='form-check-sign'>
                                    <span class='check'></span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">اغلاق</button>
                <button type="button" class="btn btn-success" id="save">حفظ</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Usage Details -->
<div class="modal fade" id="UsageModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content dark-edition">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">سجل الاستخدامات</h5>
                <button type="button" style="margin-left:10%;" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true" style="font-size:155%">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <table class="table table-hover table-bordered text-center">
                    <thead class="thead-dark">
                        <tr>
                            <th scope="col">التاريخ</th>
                            <th scope="col">اسم المستخدم</th>
                            <th scope="col">رقم الهاتف</th>
                            <th scope="col">المبلغ</th>
                        </tr>
                    </thead>
                    <tbody id="tableUsage">
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">اغلاق</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/PromoCode.js"></script>
